generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id                       String             @id @default(uuid())
  name                     String
  slug                     String             @unique
  logoUrl                  String?
  primaryColor             String             @default("#2b7fff")
  secondaryColor           String             @default("#10B981")
  subscriptionStatus       SubscriptionStatus @default(TRIAL)
  kirvanoSubscriptionId    String?
  currentPeriodEnd         DateTime?
  trialEndsAt              DateTime?
  maxUsers                 Int                @default(4)
  maxConversationsPerMonth Int                @default(1000)
  conversationsThisMonth   Int                @default(0)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  agentConfig              AgentConfig?
  analyticsDaily           AnalyticsDaily[]
  automations              Automation[]
  channels                 Channel[]
  conversations            Conversation[]
  conversationActivities   ConversationActivity[]
  leads                    Lead[]
  messageTemplates         MessageTemplate[]
  messages                 Message[]
  notes                    Note[]
  pipelineStages           PipelineStage[]
  stageHistory             StageHistory[]
  tags                     Tag[]
  users                    User[]
  webhookLogs              WebhookLog[]

  @@index([slug])
  @@map("workspaces")
}

model User {
  id                      String         @id @default(uuid())
  workspaceId             String
  email                   String
  passwordHash            String
  name                    String
  role                    UserRole       @default(AGENT)
  avatarUrl               String?
  isActive                Boolean        @default(true)
  lastActiveAt            DateTime?
  agentRole               String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  assignedByConversations Conversation[]         @relation("AssignedByConversations")
  assignedConversations   Conversation[]         @relation("AssignedConversations")
  conversationActivities  ConversationActivity[]
  notes                   Note[]
  sentMessages            Message[]
  stageHistory            StageHistory[]
  workspace               Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([email])
  @@index([workspaceId, role])
  @@map("users")
}

model Channel {
  id                String          @id @default(uuid())
  workspaceId       String
  type              ChannelType
  provider          ChannelProvider @default(META)
  name              String
  accessToken       String?
  phoneNumberId     String?
  phoneNumber       String?
  pageId            String?
  pageName          String?
  businessAccountId String?
  instanceName      String?
  instanceToken     String?
  isActive          Boolean         @default(true)
  lastSyncAt        DateTime?
  webhookVerifiedAt DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations     Conversation[]

  @@index([workspaceId])
  @@index([workspaceId, type])
  @@index([instanceName])
  @@map("channels")
}

model AgentConfig {
  id                  String    @id @default(cuid())
  workspaceId         String    @unique
  name                String    @default("Assistente")
  objective           String    @default("")
  tone                String    @default("humanizado")
  knowledgeAreas      String    @default("")
  isActive            Boolean   @default(false)
  businessHoursStart  Int?
  businessHoursEnd    Int?
  maxAiMessages       Int       @default(20)
  offHoursMessage     String    @default("Olá! No momento estamos fora do horário de atendimento. Retornaremos em breve.")
  gender              String    @default("neutro")
  personality         String    @default("")
  autoAssign          Boolean   @default(false)
  handoffInstructions String    @default("")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

model Conversation {
  id                 String             @id @default(uuid())
  workspaceId        String
  channelId          String?
  contactName        String
  contactPhone       String?
  contactEmail       String?
  contactPhotoUrl    String?
  externalId         String
  assignedToId       String?
  assignedAt         DateTime?
  assignedById       String?
  status             ConversationStatus @default(UNASSIGNED)
  pipelineStage      String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  unreadCount        Int                @default(0)
  aiEnabled          Boolean            @default(false)
  aiMessageCount     Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  assignedBy         User?              @relation("AssignedByConversations", fields: [assignedById], references: [id])
  assignedTo         User?              @relation("AssignedConversations", fields: [assignedToId], references: [id])
  channel            Channel?           @relation(fields: [channelId], references: [id], onDelete: SetNull)
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  activities         ConversationActivity[]
  conversationTags   ConversationTag[]
  lead               Lead?
  messages           Message[]
  notes              Note[]
  stageHistory       StageHistory[]

  @@unique([workspaceId, channelId, externalId])
  @@index([workspaceId])
  @@index([channelId])
  @@index([assignedToId])
  @@index([workspaceId, status])
  @@index([workspaceId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Tag {
  id               String            @id @default(cuid())
  workspaceId      String
  name             String
  color            String            @default("#3B82F6")
  createdAt        DateTime          @default(now())
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversationTags ConversationTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tags")
}

model ConversationTag {
  conversationId String
  tagId          String
  assignedAt     DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@map("conversation_tags")
}

model Note {
  id             String       @id @default(cuid())
  content        String
  conversationId String
  userId         String
  workspaceId    String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Asc)])
  @@map("notes")
}

model StageHistory {
  id             String       @id @default(cuid())
  conversationId String
  workspaceId    String
  fromStage      String?
  toStage        String?
  userId         String?
  userName       String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Asc)])
  @@map("stage_history")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  workspaceId    String
  direction      MessageDirection
  content        String
  attachments    Json             @default("[]")
  mediaType      String?
  mediaUrl       String?
  mediaMime      String?
  mediaName      String?
  transcription  String?
  externalId     String?
  status         MessageStatus    @default(SENT)
  isSystem       Boolean          @default(false)
  senderName     String?
  aiGenerated    Boolean          @default(false)
  sentById       String?
  sentAt         DateTime         @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy         User?            @relation(fields: [sentById], references: [id])
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([workspaceId])
  @@index([externalId])
  @@map("messages")
}

model PipelineStage {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  color       String    @default("#3B82F6")
  position    Int
  isDefault   Boolean   @default(false)
  isFinal     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId, position])
  @@map("pipeline_stages")
}

model Lead {
  id                 String       @id @default(uuid())
  conversationId     String       @unique
  workspaceId        String
  sourceChannel      ChannelType
  firstMessage       String?
  leadScore          Int?
  qualificationNotes String?
  convertedAt        DateTime?
  conversionValue    Decimal?     @db.Decimal(10, 2)
  lostAt             DateTime?
  lostReason         String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace          Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, convertedAt])
  @@map("leads")
}

model AnalyticsDaily {
  id                     String    @id @default(uuid())
  workspaceId            String
  date                   DateTime  @db.Date
  newConversations       Int       @default(0)
  conversationsResolved  Int       @default(0)
  conversationsActive    Int       @default(0)
  messagesReceived       Int       @default(0)
  messagesSent           Int       @default(0)
  avgFirstResponseTime   Int?
  avgResponseTime        Int?
  whatsappConversations  Int       @default(0)
  instagramConversations Int       @default(0)
  facebookConversations  Int       @default(0)
  agentStats             Json      @default("{}")
  createdAt              DateTime  @default(now())
  workspace              Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, date])
  @@index([workspaceId, date(sort: Desc)])
  @@map("analytics_daily")
}

model WebhookLog {
  id          String     @id @default(uuid())
  workspaceId String?
  source      String
  eventType   String
  payload     Json
  status      String     @default("PENDING")
  error       String?
  processedAt DateTime?
  createdAt   DateTime   @default(now())
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status])
  @@map("webhook_logs")
}

model Plan {
  id                       String   @id @default(uuid())
  name                     String
  slug                     String   @unique
  priceMonthyCents         Int
  priceAnnualCents         Int?
  kirvanoPriceIdMonthly    String?
  kirvanoPriceIdAnnual     String?
  maxUsers                 Int
  maxConversationsPerMonth Int
  maxChannels              Int
  features                 Json     @default("[]")
  isActive                 Boolean  @default(true)
  position                 Int
  createdAt                DateTime @default(now())

  @@index([isActive, position])
  @@map("plans")
}

model MessageTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("message_templates")
}

model ConversationActivity {
  id             String       @id @default(cuid())
  conversationId String
  workspaceId    String
  type           String
  description    String
  userId         String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("conversation_activities")
}

model Automation {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  isActive    Boolean   @default(true)
  trigger     String
  conditions  Json      @default("{}")
  actions     Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive])
  @@map("automations")
}

enum UserRole {
  ADMIN
  AGENT
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
}

enum ChannelProvider {
  META
  UAZAPI
}

enum ConversationStatus {
  UNASSIGNED
  ASSIGNED
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELED
  EXPIRED
}
